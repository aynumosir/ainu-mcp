# Root of the Ainu projects directory (contains ainu-corpora, ainu-dictionaries, ainu-grammar, …)
AINU_ROOT=/home/mkpoli/projects/Ainu

# Google Sheet ID for the Itak-uoeroskip glossary (default already points to it)
AINU_GLOSSARY_SHEET_ID=1zV0gl4TWV5fkf2r9i_1P1jmH_p7LOzbhZQgm7mPwDdE

# ─── Google Sheets credentials: choose ONE of the two forms below ───

# Form A — standard service-account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/ainu-glossary-service-account.json

# Form B — same env-var shape used by the existing ainu-glossary website's .env.
# Copy these directly from ainu-glossary/.env if they're already populated there.
# PRIVATE_GOOGLE_API_TYPE=service_account
# PRIVATE_GOOGLE_API_PROJECT_ID=ainu-glossary
# PRIVATE_GOOGLE_API_PRIVATE_KEY_ID=...
# PRIVATE_GOOGLE_API_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# PRIVATE_GOOGLE_API_CLIENT_EMAIL=ainu-glossary@ainu-glossary.iam.gserviceaccount.com
# PRIVATE_GOOGLE_API_CLIENT_ID=...

# ─── Important: share the sheet with the service-account email as Editor ───
# The website only needs read access; this MCP also writes, so the service
# account needs Editor (not just Viewer) on the sheet.
