{
  "name": "ainu-mcp-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Hosted Cloudflare Worker for the Ainu-language MCP server (GitHub-OAuth gated, D1-backed)",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply ainu-mcp --local",
    "db:migrate:remote": "wrangler d1 migrations apply ainu-mcp --remote",
    "db:seed:local": "wrangler d1 execute ainu-mcp --local --file=./seed/seed.sql",
    "db:seed:remote": "wrangler d1 execute ainu-mcp --remote --file=./seed/seed.sql"
  },
  "dependencies": {
    "@cloudflare/workers-oauth-provider": "^0.7.0",
    "@libsql/client": "^0.17.3",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "agents": "^0.13.3",
    "ainconv": "^0.5.1",
    "hono": "^4.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.8.0",
    "wrangler": "^4.20.0"
  }
}
