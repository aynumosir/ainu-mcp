{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ainu-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },

  // Custom domain — aynu.org is on this Cloudflare account, so wrangler creates
  // the DNS record + cert for mcp.aynu.org on deploy. The GitHub App callback
  // (https://mcp.aynu.org/callback) and the OAuth issuer both resolve here.
  "routes": [
    {
      "pattern": "mcp.aynu.org",
      "custom_domain": true
    }
  ],

  // The MCP server is a SQLite-backed Durable Object (free-tier eligible).
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_OBJECT",
        "class_name": "AinuMCP"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["AinuMCP"]
    }
  ],

  // OAuth token/grant storage for @cloudflare/workers-oauth-provider.
  // Create with: wrangler kv namespace create OAUTH_KV
  "kv_namespaces": [
    {
      "binding": "OAUTH_KV",
      "id": "ad96bba28e494d2d911fc7bba6cb0e4f"
    }
  ],

  // Service bindings to sibling Aynu.org Workers (same account). Worker-to-Worker
  // calls — no public internet hop, no auth dance. The morpheme/lexeme and
  // textual-sources tools proxy the read APIs these apps expose.
  "services": [
    { "binding": "MDB", "service": "ainu-mdb" },
    { "binding": "SOURCES", "service": "ainu-sources" },
    // Corpus read API (corpus.aynu.org). Corpus search/freq/stopwords/candidates
    // were extracted here; the corpus-source.ts dispatcher uses this binding when
    // USE_CORPUS_API === "true", else falls back to the direct env.DB path.
    { "binding": "CORPUS", "service": "ainu-corpora-api" }
  ],

  // Reference data (corpus / dictionaries / grammar / frequency) now lives in
  // Turso (libSQL), not D1 — the D1 free-tier per-database size cap blocked
  // writes at ~615 MB. env.DB is a libSQL-backed shim (src/libsql.ts) created in
  // mcp.ts from the DATABASE_URL / DATABASE_AUTH_TOKEN secrets (wrangler secret
  // put). Schema lives in migrations/ and is applied to Turso with
  // `turso db shell ainu-mcp < migrations/*.sql`; data is loaded by the ETL.

  // The itak.aynu.org site cache bucket (table.json / sheets.json).
  // This is the SAME bucket the website reads from; binding replaces boto3.
  "r2_buckets": [
    {
      "binding": "SITE_CACHE",
      // The existing itak.aynu.org cache bucket (the site reads table.json /
      // sheets.json from here). Confirm this is the bucket your site reads.
      "bucket_name": "ainu-glossary"
    }
  ],

  // Non-secret config. Secrets (GitHub OAuth app, Google service account,
  // cookie key) are set via `wrangler secret put` — see worker/README.md.
  "vars": {
    "ALLOWED_ORG": "aynumosir",
    "ALLOWED_USERS": "",
    "GLOSSARY_SHEET_ID": "1zV0gl4TWV5fkf2r9i_1P1jmH_p7LOzbhZQgm7mPwDdE",
    // Cutover flag for corpus reads: "true" routes corpus search/freq/stopwords
    // /candidates through the CORPUS service binding (corpus.aynu.org); any other
    // value keeps the legacy direct-DB path. Flip to "true" after shadow-testing.
    "USE_CORPUS_API": "true"
  }
}
